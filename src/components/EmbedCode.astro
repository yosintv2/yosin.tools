---
export interface Props {
  slug: string;
  label: string;
}

const { slug, label } = Astro.props;
const site = 'https://singhyogendra.com.np';
const toolUrl = `${site}/${slug}`;
const embedHtml = `<iframe src="${toolUrl}" width="100%" height="600" frameborder="0" allowtransparency="true" style="border:1px solid #e5e7eb;border-radius:10px;max-width:100%"></iframe>\n<p style="font-size:12px;color:#6b7280;text-align:center;margin-top:4px">Powered by <a href="${toolUrl}" target="_blank" style="color:#3b82f6;text-decoration:none;font-weight:600">YoSin Tools - ${label}</a></p>`;
---

<details class="embed-block block">
  <summary class="block-title">
    Embed This Tool
    <div class="toolbar">
      <button class="icon" data-embed-copy title="Copy embed code">
        <img src="/assets/images/copy.svg" alt="Copy">
      </button>
    </div>
  </summary>
  <div class="embed-code-box">
    <textarea id="embed-code" readonly rows="3">{embedHtml}</textarea>
  </div>
  <div class="embed-note">
    Copy the HTML code above to embed this tool on your website.
    It includes a backlink to YoSin Tools as required.
  </div>
</details>

<script>
  const copyBtn = document.querySelector('[data-embed-copy]');
  const embedTextarea = document.getElementById('embed-code');
  if (copyBtn && embedTextarea) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(embedTextarea.value);
        const msg = document.getElementById('message');
        if (msg) {
          msg.textContent = 'Embed code copied!';
          msg.style.display = 'block';
          setTimeout(() => { msg.style.display = 'none'; }, 2000);
        }
      } catch {}
    });
  }
</script>
